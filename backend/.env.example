# Supabase Postgres connection string
# Get this from Supabase Project Settings -> Database -> Connection string (URI, use "Session pooler" for Render)
# Example: postgresql://postgres.xxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/reloop

# Comma-separated list of allowed frontend origins for CORS
FRONTEND_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Below this confidence (0-1), the frontend must ask the user to verify/correct the classification
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.6
